<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>FitSphere Dashboard</title>
  <link rel="stylesheet" href="/css/bootstrap.min.css">

  <style>
    body {
      background: #0a0a0a;
      color: #f5f5f0;
      font-family: 'DM Sans', sans-serif;
    }

    .sidebar {
      height: 100vh;
      background: #141414;
      padding: 20px;
    }

    .sidebar h2 {
      color: #e8a020;
      font-weight: bold;
    }

    .sidebar a {
      display: block;
      color: #d4d4d4;
      margin: 10px 0;
      text-decoration: none;
    }

    .sidebar a:hover {
      color: #e8a020;
    }

    .card {
      background: #1c1c1c;
      border: 1px solid #3d3d3d;
      color: white;
    }

    .stat {
      font-size: 22px;
      font-weight: bold;
      color: #e8a020;
    }

    .topbar {
      background: #141414;
      padding: 15px;
      border-bottom: 1px solid #3d3d3d;
    }

    .form-control,
    .form-control:focus {
      background: #101010;
      color: #f5f5f0;
      border-color: #3d3d3d;
      box-shadow: none;
    }

    .btn-gold {
      background: #e8a020;
      color: #000;
      border: none;
      font-weight: 700;
    }

    .btn-gold:hover {
      background: #f2bc55;
      color: #000;
    }
  </style>
</head>

<body>

<div class="container-fluid">
  <div class="row">

    <!-- SIDEBAR -->
    <div class="col-md-2 sidebar">
      <h2>FitSphere</h2>
      <hr>

      <a href="/dashboard">Dashboard</a>
      <a href="/dashboard/bookings/new">Book Service</a>
      <a href="/dashboard/profile">Profile</a>
      <a href="/dashboard/membership">Membership</a>
      <a href="/logout">Logout</a>
    </div>

    <!-- MAIN CONTENT -->
    <div class="col-md-10">

      <!-- TOP BAR -->
      <div class="topbar d-flex justify-content-between">
        <h4>Welcome, <%= user.firstName %> </h4>
        <span><%= user.email %></span>
      </div>

      <div class="p-4">

        <!-- STATS -->
        <div class="row mb-4">

          <div class="col-md-3">
            <div class="card p-3 text-center">
              <p>Membership Plan</p>
              <div class="stat"><%= user.plan || "Basic" %></div>
            </div>
          </div>

          <div class="col-md-3">
            <div class="card p-3 text-center">
              <p>BMI</p>
              <div class="stat"><%= user.bmi || "N/A" %></div>
            </div>
          </div>

          <div class="col-md-3">
            <div class="card p-3 text-center">
              <p>Weight</p>
              <div class="stat"><%= user.currentWeight || "N/A" %> kg</div>
            </div>
          </div>

          <div class="col-md-3">
            <div class="card p-3 text-center">
              <p>Height</p>
              <div class="stat"><%= user.height || "N/A" %> cm</div>
            </div>
          </div>

        </div>

        <div class="row g-4">
          <div class="col-lg-7">
            <div class="card p-3 h-100">
              <h5>Upcoming Sessions</h5>
              <hr>

              <% if (upcomingSessions.length > 0) { %>
                <% upcomingSessions.forEach(session => { %>
                  <div class="d-flex justify-content-between mb-2">
                    <span><%= session.date || session.preferredDate %> - <%= session.type || session.serviceTitle %></span>
                    <span><%= session.trainer || session.preferredTime %></span>
                  </div>
                <% }) %>
              <% } else { %>
                <p>No sessions booked</p>
              <% } %>
            </div>
          </div>

          <div class="col-lg-5">
            <div class="card p-3 h-100">
              <h5>BMI Calculator</h5>
              <hr>

              <form action="/dashboard/bmi/save" method="POST">
                <div class="mb-3">
                  <label for="weight" class="form-label">Weight (kg)</label>
                  <input type="number" step="0.1" min="1" class="form-control" id="weight" name="weight" value="<%= user.currentWeight || '' %>" required>
                </div>

                <div class="mb-3">
                  <label for="height" class="form-label">Height (cm)</label>
                  <input type="number" step="0.1" min="1" class="form-control" id="height" name="height" value="<%= user.height || '' %>" required>
                </div>

                <div class="mb-3">
                  <label for="bmi" class="form-label">BMI</label>
                  <input type="number" step="0.01" class="form-control" id="bmi" name="bmi" value="<%= user.bmi || '' %>" readonly required>
                </div>

                <button type="submit" class="btn btn-gold w-100">Save BMI</button>
              </form>
            </div>
          </div>
        </div>

      </div>

    </div>
  </div>
</div>

<script>
  const weightInput = document.getElementById('weight');
  const heightInput = document.getElementById('height');
  const bmiInput = document.getElementById('bmi');

  function updateBMI() {
    const weight = parseFloat(weightInput.value);
    const heightCm = parseFloat(heightInput.value);

    if (!weight || !heightCm) {
      bmiInput.value = '';
      return;
    }

    const heightM = heightCm / 100;
    const bmi = weight / (heightM * heightM);
    bmiInput.value = bmi.toFixed(2);
  }

  weightInput.addEventListener('input', updateBMI);
  heightInput.addEventListener('input', updateBMI);
</script>

</body>
</html>
