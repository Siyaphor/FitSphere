<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Membership</title>
  <link rel="stylesheet" href="/css/bootstrap.min.css">
  <style>
    body {
      background: #0a0a0a;
      color: #f5f5f0;
      font-family: 'DM Sans', sans-serif;
    }

    .sidebar {
      min-height: 100vh;
      background: #141414;
      padding: 20px;
    }

    .sidebar h2 {
      color: #e8a020;
      font-weight: bold;
    }

    .sidebar a {
      display: block;
      color: #d4d4d4;
      margin: 10px 0;
      text-decoration: none;
    }

    .sidebar a:hover,
    .sidebar a.active {
      color: #e8a020;
    }

    .topbar {
      background: #141414;
      padding: 15px;
      border-bottom: 1px solid #3d3d3d;
    }

    .panel {
      background: #1c1c1c;
      border: 1px solid #3d3d3d;
      border-radius: 8px;
      color: #fff;
    }

    .stat {
      color: #e8a020;
      font-size: 34px;
      font-weight: 800;
    }

    .detail-label {
      color: #b8b8b8;
      margin-bottom: 4px;
    }

    .detail-value {
      font-size: 18px;
      font-weight: 700;
    }

    .btn-gold {
      background: #e8a020;
      color: #000;
      border: none;
      font-weight: 700;
    }

    .btn-gold:hover {
      background: #f2bc55;
      color: #000;
    }
  </style>
</head>
<body>
  <div class="container-fluid">
    <div class="row">
      <div class="col-md-2 sidebar">
        <h2>FitSphere</h2>
        <hr>
        <a href="/dashboard">Dashboard</a>
        <a href="/dashboard/bookings/new">Book Service</a>
        <a href="/dashboard/profile">Profile</a>
        <a href="/dashboard/membership" class="active">Membership</a>
        <a href="/logout">Logout</a>
      </div>

      <div class="col-md-10">
        <div class="topbar d-flex justify-content-between">
          <h4>Membership</h4>
          <span><%= user.email %></span>
        </div>

        <div class="p-4">
          <div class="panel p-4 mb-4">
            <p class="mb-1">Current Plan</p>
            <div class="stat"><%= user.plan || 'Basic' %></div>
            <p class="mb-0">Your active FitSphere membership details.</p>
          </div>

          <div class="row g-4">
            <div class="col-md-4">
              <div class="panel p-4 h-100">
                <div class="detail-label">Plan Start Date</div>
                <div class="detail-value"><%= planStartDate.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></div>
              </div>
            </div>

            <div class="col-md-4">
              <div class="panel p-4 h-100">
                <div class="detail-label">Plan End Date</div>
                <div class="detail-value"><%= planEndDate.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></div>
              </div>
            </div>

            <div class="col-md-4">
              <div class="panel p-4 h-100">
                <div class="detail-label">Time Period</div>
                <div class="detail-value"><%= Math.max(1, Math.ceil((planEndDate - planStartDate) / (1000 * 60 * 60 * 24))) %> days</div>
              </div>
            </div>
          </div>

          <div class="panel p-4 mt-4">
            <h5 class="mb-3">Member Details</h5>
            <p class="mb-2"><strong>Name:</strong> <%= user.firstName %> <%= user.lastName || '' %></p>
            <p class="mb-2"><strong>Contact No.:</strong> <%= user.phone || 'Not added' %></p>
            <p class="mb-0"><strong>Email:</strong> <%= user.email %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
