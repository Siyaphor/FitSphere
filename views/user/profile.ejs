<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Profile</title>
  <link rel="stylesheet" href="/css/bootstrap.min.css">
  <style>
    body {
      background: #0a0a0a;
      color: #f5f5f0;
      font-family: 'DM Sans', sans-serif;
    }

    .sidebar {
      min-height: 100vh;
      background: #141414;
      padding: 20px;
    }

    .sidebar h2 {
      color: #e8a020;
      font-weight: bold;
    }

    .sidebar a {
      display: block;
      color: #d4d4d4;
      margin: 10px 0;
      text-decoration: none;
    }

    .sidebar a:hover,
    .sidebar a.active {
      color: #e8a020;
    }

    .topbar {
      background: #141414;
      padding: 15px;
      border-bottom: 1px solid #3d3d3d;
    }

    .panel {
      background: #1c1c1c;
      border: 1px solid #3d3d3d;
      border-radius: 8px;
      color: #fff;
    }

    .profile-photo {
      width: 150px;
      height: 150px;
      border-radius: 8px;
      object-fit: cover;
      border: 2px solid #e8a020;
      background: #111;
    }

    .placeholder-photo {
      width: 150px;
      height: 150px;
      border-radius: 8px;
      border: 2px solid #e8a020;
      display: grid;
      place-items: center;
      background: #111;
      color: #e8a020;
      font-size: 44px;
      font-weight: 800;
    }

    .form-control,
    .form-control:focus {
      background: #111;
      border-color: #3d3d3d;
      color: #dcdcdc;
      box-shadow: none;
    }

    .btn-gold {
      background: #e8a020;
      color: #000;
      border: none;
      font-weight: 700;
    }

    .btn-gold:hover {
      background: #f2bc55;
      color: #000;
    }
  </style>
</head>
<body>
  <div class="container-fluid">
    <div class="row">
      <div class="col-md-2 sidebar">
        <h2>FitSphere</h2>
        <hr>
        <a href="/dashboard">Dashboard</a>
        <a href="/dashboard/bookings/new">Book Service</a>
        <a href="/dashboard/profile" class="active">Profile</a>
        <a href="/dashboard/membership">Membership</a>
        <a href="/logout">Logout</a>
      </div>

      <div class="col-md-10">
        <div class="topbar d-flex justify-content-between">
          <h4>Profile</h4>
          <span><%= user.email %></span>
        </div>

        <div class="p-4">
          <% if (typeof success !== 'undefined' && success) { %>
            <div class="alert alert-success"><%= success %></div>
          <% } %>

          <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger"><%= error %></div>
          <% } %>

          <div class="row g-4">
            <div class="col-lg-4">
              <div class="panel p-4 h-100 text-center">
                <% if (user.profilePicture) { %>
                  <img src="<%= user.profilePicture %>" alt="Profile picture" class="profile-photo mb-3">
                <% } else { %>
                  <div class="placeholder-photo mx-auto mb-3"><%= (user.firstName || 'U').charAt(0).toUpperCase() %></div>
                <% } %>
                <h5 class="mb-1"><%= user.firstName %> <%= user.lastName || '' %></h5>
                <p class="mb-2"><%= user.phone || 'Contact no. not added' %></p>
                <p class="mb-0"><%= user.plan || 'Basic' %> Member</p>
              </div>
            </div>

            <div class="col-lg-8">
              <div class="panel p-4">
                <h5 class="mb-3">Update Details</h5>
                <form action="/dashboard/profile" method="POST" enctype="multipart/form-data">
                  <div class="row">
                    <div class="col-md-6 mb-3">
                      <label for="firstName" class="form-label">First Name</label>
                      <input type="text" id="firstName" name="firstName" class="form-control" value="<%= user.firstName || '' %>" required>
                    </div>

                    <div class="col-md-6 mb-3">
                      <label for="lastName" class="form-label">Last Name</label>
                      <input type="text" id="lastName" name="lastName" class="form-control" value="<%= user.lastName || '' %>">
                    </div>
                  </div>

                  <div class="mb-3">
                    <label for="phone" class="form-label">Contact No.</label>
                    <input type="tel" id="phone" name="phone" class="form-control" value="<%= user.phone || '' %>" placeholder="+91 98765 43210">
                  </div>

                  <div class="mb-3">
                    <label for="email" class="form-label">Email</label>
                    <input type="email" id="email" class="form-control" value="<%= user.email || '' %>" >
                  </div>

                  <div class="row">
                    <div class="col-md-6 mb-3">
                      <label for="height" class="form-label">Height (cm)</label>
                      <input type="number" step="0.1" min="1" id="height" name="height" class="form-control" value="<%= user.height || '' %>">
                    </div>

                    <div class="col-md-6 mb-3">
                      <label for="currentWeight" class="form-label">Current Weight (kg)</label>
                      <input type="number" step="0.1" min="1" id="currentWeight" name="currentWeight" class="form-control" value="<%= user.currentWeight || '' %>">
                    </div>
                  </div>

                  <div class="mb-4">
                    <label for="profilePicture" class="form-label">Profile Picture</label>
                    <input type="file" id="profilePicture" name="profilePicture" class="form-control" accept="image/*">
                  </div>

                  <button type="submit" class="btn btn-gold">Save Profile</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
