<!DOCTYPE html>
<html>
<head>
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="/css/bootstrap.min.css">

  <style>
    body {
      background: #0a0a0a;
      color: #f5f5f0;
    }

    .card {
      background: #1c1c1c;
      border: 1px solid #3d3d3d;
    }

    .btn-gold {
      background: #e8a020;
      color: black;
    }
  </style>
</head>

<body>

<div class="container mt-4">

  <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
    <h2 class="mb-0">Welcome Admin: <%= admin.email %></h2>
    <div class="d-flex gap-2">
      <a href="/admin/services/new" class="btn btn-gold">Manage Services</a>
      <a href="/logout" class="btn btn-danger">Logout</a>
    </div>
  </div>

  <div class="card p-3">
    <h4>All Users</h4>
    <hr>

    <table class="table table-dark table-striped">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Plan</th>
          <th>Action</th>
        </tr>
      </thead>

      <tbody>
        <% users.forEach(user => { %>
          <tr>
            <td><%= user.firstName %> <%= user.lastName %></td>
            <td><%= user.email %></td>
            <td><%= user.plan || "Basic" %></td>
            <td>
              <a href="/admin/delete/<%= user._id %>" class="btn btn-sm btn-danger">
                Delete
              </a>
            </td>
          </tr>
        <% }) %>
      </tbody>

    </table>
  </div>

  <div class="card p-3 mt-4">
    <h4>Form Submissions</h4>
    <hr>

    <table class="table table-dark table-striped">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Phone</th>
          <th>Type</th>
          <th>Plan / Subject</th>
          <th>Message</th>
        </tr>
      </thead>

      <tbody>
        <% if (!forms.length) { %>
          <tr>
            <td colspan="6">No form submissions yet.</td>
          </tr>
        <% } %>
        <% forms.forEach(form => { %>
          <tr>
            <td><%= form.name || ((form.firstName || '') + ' ' + (form.lastName || '')).trim() %></td>
            <td><%= form.email %></td>
            <td><%= form.phone || '-' %></td>
            <td><%= form.type %></td>
            <td><%= form.plan || form.subject || '-' %></td>
            <td><%= form.message || '-' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="card p-3 mt-4">
    <h4>Service Bookings</h4>
    <hr>

    <table class="table table-dark table-striped">
      <thead>
        <tr>
          <th>User</th>
          <th>Service</th>
          <th>Date</th>
          <th>Time</th>
          <th>Status</th>
        </tr>
      </thead>

      <tbody>
        <% if (!bookings.length) { %>
          <tr>
            <td colspan="5">No service bookings yet.</td>
          </tr>
        <% } %>
        <% bookings.forEach(booking => { %>
          <tr>
            <td><%= booking.user ? ((booking.user.firstName || '') + ' ' + (booking.user.lastName || '')).trim() || booking.user.email : '-' %></td>
            <td><%= booking.serviceTitle %></td>
            <td><%= booking.preferredDate %></td>
            <td><%= booking.preferredTime %></td>
            <td><%= booking.status %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

</div>

</body>
</html>
