<%- include('./partials/header', { pageTitle: 'Our Trainers' }) %>

<div style="background:var(--charcoal); padding:5rem 2.5rem 3rem; text-align:center; border-bottom:1px solid var(--steel);">
  <p class="section-label" style="display:block; margin-bottom:0.5rem;">Expert Staff</p>
  <h1 style="font-family:'Bebas Neue',sans-serif; font-size:clamp(2.5rem,6vw,5rem); color:var(--white); margin-bottom:0.75rem;">
    Meet Your Coaches
  </h1>
  <p style="color:var(--muted); font-size:1rem; max-width:500px; margin:0 auto;">
    Certified professionals dedicated to pushing you beyond your limits — safely and effectively.
  </p>
</div>

<section class="section trainers-section">
  <div class="section-inner">

    <div class="trainers-grid" style="grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));">

      <!-- Trainer 1 -->
      <div class="trainer-card">
        <div class="trainer-img-wrap">
          <img src="/images/trainer-1.avif" alt="Arjun Singh">
        </div>
        <div class="trainer-overlay">
          <div class="trainer-name">Arjun Singh</div>
          <div class="trainer-role">Strength &amp; Powerlifting</div>
        </div>
      </div>

      <!-- Trainer 2 -->
      <div class="trainer-card">
        <div class="trainer-img-wrap">
          <img src="/images/trainer-2.jpg" alt="Simran Kaur">
        </div>
        <div class="trainer-overlay">
          <div class="trainer-name">Simran Kaur</div>
          <div class="trainer-role">Yoga &amp; Flexibility</div>
        </div>
      </div>

      <!-- Trainer 3 -->
      <div class="trainer-card">
        <div class="trainer-img-wrap">
          <img src="/images/trainer-3.avif" alt="Rahul Verma">
        </div>
        <div class="trainer-overlay">
          <div class="trainer-name">Rahul Verma</div>
          <div class="trainer-role">HIIT &amp; Cardio</div>
        </div>
      </div>

      <!-- Trainer 4 -->
      <div class="trainer-card">
        <div class="trainer-img-wrap">
          <img src="/images/trainer-4.avif" alt="Priya Mehta">
        </div>
        <div class="trainer-overlay">
          <div class="trainer-name">Priya Mehta</div>
          <div class="trainer-role">Nutrition &amp; Wellness</div>
        </div>
      </div>

      <!-- Trainer 5 -->
      <div class="trainer-card">
        <div class="trainer-img-wrap">
          <img src="/images/trainer-1.avif" alt="Karan Sharma">
        </div>
        <div class="trainer-overlay">
          <div class="trainer-name">Karan Sharma</div>
          <div class="trainer-role">CrossFit Specialist</div>
        </div>
      </div>

      <!-- Trainer 6 -->
      <div class="trainer-card">
        <div class="trainer-img-wrap">
          <img src="/images/trainer-2.jpg" alt="Neha Anand">
        </div>
        <div class="trainer-overlay">
          <div class="trainer-name">Neha Anand</div>
          <div class="trainer-role">Pilates &amp; Core Training</div>
        </div>
      </div>

    </div>

    <!-- CTA -->
    <div style="text-align:center; margin-top:4rem;">
      <p style="color:var(--muted); font-size:0.9rem; margin-bottom:1.5rem;">
        Ready to work with one of our coaches?
      </p>
      <a href="/form" class="btn-primary-gold">Book a Session</a>
    </div>

  </div>
</section>

<%- include('./partials/footer') %>