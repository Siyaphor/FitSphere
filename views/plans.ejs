<%- include('./partials/header', { pageTitle: 'Membership Plans' }) %>

<div style="background:var(--charcoal); padding:5rem 2.5rem 3rem; text-align:center; border-bottom:1px solid var(--steel);">
  <p class="section-label" style="display:block; margin-bottom:0.5rem;">Membership</p>
  <h1 style="font-family:'Bebas Neue',sans-serif; font-size:clamp(2.5rem,6vw,5rem); color:var(--white); margin-bottom:0.75rem;">Choose Your Plan</h1>
  <p style="color:var(--muted); font-size:1rem; max-width:500px; margin:0 auto;">Transparent pricing. No joining fee. No lock-in. Just results.</p>
</div>

<section class="section plans-section">
  <div class="section-inner">
    <div class="plans-grid">

      <div class="plan-card">
        <img src="/images/gym plan.avif" alt="Basic Plan" class="plan-img">
        <h3 class="plan-name">Basic</h3>
        <div class="plan-price">₹1,499<span>/mo</span></div>
        <p class="plan-period">Billed monthly · Cancel anytime</p>
        <ul class="plan-features">
          <li><i class="fi">✦</i> Full Gym Floor Access</li>
          <li><i class="fi">✦</i> Cardio Zone</li>
          <li><i class="fi">✦</i> 2 Group Classes / Week</li>
          <li><i class="fi">✦</i> Locker Room Access</li>
          <li><i class="fi fx">✗</i> <span style="color:var(--steel)">Personal Trainer</span></li>
          <li><i class="fi fx">✗</i> <span style="color:var(--steel)">Nutrition Consult</span></li>
          <li><i class="fi fx">✗</i> <span style="color:var(--steel)">Recovery Zone</span></li>
        </ul>
        <a href="/form" class="btn-outline-gold">Get Started</a>
      </div>

      <div class="plan-card featured">
        <img src="/images/plan2 gym.avif" alt="Premium Plan" class="plan-img">
        <h3 class="plan-name">Premium</h3>
        <div class="plan-price">₹3,299<span>/mo</span></div>
        <p class="plan-period">Billed monthly · Cancel anytime</p>
        <ul class="plan-features">
          <li><i class="fi">✦</i> Everything in Basic</li>
          <li><i class="fi">✦</i> Unlimited Group Classes</li>
          <li><i class="fi">✦</i> 4 PT Sessions / Month</li>
          <li><i class="fi">✦</i> Body Composition Analysis</li>
          <li><i class="fi">✦</i> Sauna &amp; Recovery Zone</li>
          <li><i class="fi fx">✗</i> <span style="color:var(--steel)">Nutrition Consult</span></li>
          <li><i class="fi fx">✗</i> <span style="color:var(--steel)">Guest Passes</span></li>
        </ul>
        <a href="/form" class="btn-primary-gold">Get Started</a>
      </div>

      <div class="plan-card">
        <img src="/images/gym front.avif" alt="Elite Plan" class="plan-img">
        <h3 class="plan-name">Elite</h3>
        <div class="plan-price">₹5,999<span>/mo</span></div>
        <p class="plan-period">Billed monthly · Cancel anytime</p>
        <ul class="plan-features">
          <li><i class="fi">✦</i> Everything in Premium</li>
          <li><i class="fi">✦</i> Unlimited PT Sessions</li>
          <li><i class="fi">✦</i> Monthly Nutrition Consult</li>
          <li><i class="fi">✦</i> Priority Class Booking</li>
          <li><i class="fi">✦</i> Guest Pass (2/month)</li>
          <li><i class="fi">✦</i> Exclusive Member Lounge</li>
          <li><i class="fi">✦</i> Branded FitSphere Kit</li>
        </ul>
        <a href="/form" class="btn-outline-gold">Get Started</a>
      </div>

    </div>

    <!-- FAQ / note -->
    <div style="margin-top:4rem; text-align:center;">
      <p style="color:var(--muted); font-size:0.9rem; max-width:560px; margin:0 auto;">
        Not sure which plan is right for you?
        <a href="/contact" style="color:var(--gold); font-weight:600;">Talk to our team</a>
        — we'll help you find the perfect fit. First trial session is always free.
      </p>
    </div>

  </div>
</section>

<%- include('./partials/footer') %>
